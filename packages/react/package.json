{
  "name": "@nachi/react",
  "version": "0.0.0",
  "description": "Thin React Three Fiber lifecycle bindings for nachi VFX systems",
  "keywords": [
    "react",
    "react-three-fiber",
    "three.js",
    "webgpu",
    "vfx"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/react"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nachi/core": "workspace:^"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=9.0.0 <10.0.0",
    "@types/three": ">=0.185.0 <0.186.0",
    "react": ">=19.0.0 <20.0.0",
    "three": "0.185.1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@react-three/fiber": "9.3.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "@types/react-test-renderer": "19.1.0",
    "@types/three": "0.185.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-test-renderer": "19.1.1",
    "three": "0.185.1"
  }
}
