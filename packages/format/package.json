{
  "name": "@nachi-vfx/format",
  "version": "0.2.2",
  "description": "Versioned JSON effect assets, validation, migration, and inheritance for nachi",
  "keywords": [
    "three.js",
    "webgpu",
    "vfx",
    "json",
    "assets"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/format"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nachi-vfx/core": "workspace:^"
  },
  "devDependencies": {
    "@nachi-vfx/trails": "workspace:^"
  },
  "publishConfig": {
    "access": "public"
  }
}
