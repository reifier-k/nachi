{
  "name": "@nachi-vfx/core",
  "version": "0.2.0",
  "description": "GPU-first deterministic particle simulation and VFX runtime for Three.js",
  "keywords": [
    "three.js",
    "webgpu",
    "vfx",
    "particles",
    "simulation"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/core"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
