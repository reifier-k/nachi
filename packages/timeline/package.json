{
  "name": "@nachi-vfx/timeline",
  "version": "0.0.0",
  "description": "Deterministic effect-local sequencing, hit stop, camera shake, and mesh-fx composition for nachi",
  "keywords": [
    "three.js",
    "webgpu",
    "vfx",
    "timeline",
    "sequencer"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/timeline"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nachi-vfx/core": "workspace:^",
    "@nachi-vfx/mesh-fx": "workspace:^"
  },
  "peerDependencies": {
    "@types/three": ">=0.185.0 <0.186.0",
    "three": "0.185.1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/three": "0.185.0",
    "three": "0.185.1"
  }
}
