{
  "name": "@nachi-vfx/three",
  "version": "0.1.0",
  "description": "Three.js WebGPU runtime adapter and draw materializers for nachi VFX",
  "keywords": [
    "three.js",
    "webgpu",
    "vfx",
    "particles",
    "runtime-adapter"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/three"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nachi-vfx/core": "workspace:^"
  },
  "peerDependencies": {
    "@types/three": ">=0.185.0 <0.186.0",
    "three": "0.185.1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@nachi-vfx/trails": "workspace:^",
    "@types/three": "0.185.0",
    "three": "0.185.1"
  }
}
