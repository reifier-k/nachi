{
  "name": "@nachi-vfx/mesh-fx",
  "version": "0.2.3",
  "description": "Procedural Three.js VFX meshes and declarative NodeMaterial composition",
  "keywords": [
    "three.js",
    "tsl",
    "webgpu",
    "mesh",
    "vfx"
  ],
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git",
    "directory": "packages/mesh-fx"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../tools/check-package-esm.mjs .",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nachi-vfx/tsl-kit": "workspace:^"
  },
  "peerDependencies": {
    "@types/three": ">=0.185.0 <0.186.0",
    "three": "0.185.1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/three": "0.185.0",
    "three": "0.185.1"
  }
}
