{
  "name": "nachi-workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reifier-k/nachi.git"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter @nachi-vfx/playground dev",
    "showcase:dev": "pnpm --filter @nachi-vfx/showcase dev",
    "showcase:build": "pnpm --filter @nachi-vfx/showcase build",
    "docs:dev": "pnpm --filter @nachi-vfx/docs dev",
    "docs:build": "pnpm --filter @nachi-vfx/docs build",
    "build": "pnpm -r --if-present build",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome lint .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version && node tools/sync-package-versions.mjs",
    "esm:check": "node tools/check-all-package-esm.mjs",
    "esm-all": "node tools/check-all-package-esm.mjs",
    "golden:regress": "node tools/golden-runner.mjs",
    "verify:gpu": "node tools/verification-runner.mjs",
    "release:dry": "pnpm build && pnpm esm:check && node tools/release-dry.mjs",
    "release": "pnpm build && pnpm esm:check && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@changesets/cli": "2.31.1",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "playwright": "1.61.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild": "0.28.1"
    }
  }
}
