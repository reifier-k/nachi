{
  "name": "nachi-workspace",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter @nachi/playground dev",
    "build": "pnpm -r --if-present build",
    "test": "vitest run",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.13",
    "eslint": "9.39.2",
    "globals": "16.5.0",
    "playwright": "1.61.1",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vitest": "4.0.18"
  }
}
